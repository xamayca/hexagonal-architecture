{
    "name": "xamayca/hexagonal-architecture",
    "description": "PHP project demonstrating Hexagonal Architecture (Ports & Adapters) implementation.",
    "version": "0.1.0",
    "type": "project",
    "keywords": [
        "php",
        "hexagonal",
        "architecture",
        "ports",
        "adapters"
    ],
    "homepage": "https://github.com/xamayca/hexagonal-architecture",
    "license": "MIT",
    "authors": [
        {
            "name": "xamayca",
            "email": "christopher.hariouat@gmail.com",
            "homepage": "https://github.com/xamayca",
            "role": "Developer"
        }
    ],
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/xamayca/hexagonal-architecture"
        }
    ],
    "require": {
        "php": "^8.5"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "Domain\\": "src/User/Domain",
            "Application\\": "src/Application",
            "Infrastructure\\": "src/User/Infrastructure"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "phpstan": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/phpunit",
        "test:unit": "@test --testsuite=Unit",
        "test:integration": "@test --testsuite=Integration",
        "test:functional": "@test --testsuite=Functional"
    }
}
